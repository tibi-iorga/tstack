#!/usr/bin/env bash

set -e

SKILLS_DIR="$HOME/.claude/skills"
TIBI_DIR="$SKILLS_DIR/tstack"
CLAUDE_MD="$HOME/.claude/CLAUDE.md"
IMPORT_LINE="@~/.claude/skills/tstack/CLAUDE.md"

echo ""
echo "tstack setup"
echo "------------"

# Clone or update the repo
if [ -d "$TIBI_DIR/.git" ]; then
  echo "Updating tstack..."
  cd "$TIBI_DIR" && git pull
else
  echo "Installing tstack..."
  mkdir -p "$SKILLS_DIR"
  git clone https://github.com/tibi-iorga/tstack.git "$TIBI_DIR"
fi

# Add reference to ~/.claude/CLAUDE.md if not already there
if [ -f "$CLAUDE_MD" ]; then
  if grep -q "tstack" "$CLAUDE_MD"; then
    echo "tstack already registered in ~/.claude/CLAUDE.md"
  else
    echo "" >> "$CLAUDE_MD"
    echo "$IMPORT_LINE" >> "$CLAUDE_MD"
    echo "Registered tstack in ~/.claude/CLAUDE.md"
  fi
else
  mkdir -p "$HOME/.claude"
  echo "$IMPORT_LINE" > "$CLAUDE_MD"
  echo "Created ~/.claude/CLAUDE.md and registered tstack"
fi

# Make update check script executable
chmod +x "$TIBI_DIR/bin/tstack-update-check" 2>/dev/null || true

# Install each skill as ~/.claude/skills/<name>/SKILL.md
count=0
for skill_dir in "$TIBI_DIR/skills"/*/; do
  skill_name=$(basename "$skill_dir")
  target_dir="$SKILLS_DIR/$skill_name"
  mkdir -p "$target_dir"
  cp "$skill_dir/SKILL.md" "$target_dir/SKILL.md"
  count=$((count + 1))
done
echo "Installed $count skills to ~/.claude/skills/"

echo ""
echo "Done. Restart Claude Code and type / to see all tstack skills."
echo ""
