#!/usr/bin/env bash
# tstack-update-check — checks if a newer version is available on GitHub.
#
# Output (one line, or nothing):
#   UPGRADE_AVAILABLE <local> <remote>   — remote VERSION differs from local
#   (nothing)                            — up to date or check failed
set -euo pipefail

TSTACK_DIR="${TSTACK_DIR:-$(cd "$(dirname "$0")/.." && pwd)}"
STATE_DIR="$HOME/.tstack"
CACHE_FILE="$STATE_DIR/last-update-check"
VERSION_FILE="$TSTACK_DIR/VERSION"
REMOTE_URL="https://raw.githubusercontent.com/tibi-iorga/tstack/main/VERSION"

# Read local version
LOCAL=""
if [ -f "$VERSION_FILE" ]; then
  LOCAL="$(cat "$VERSION_FILE" 2>/dev/null | tr -d '[:space:]')"
fi
if [ -z "$LOCAL" ]; then
  exit 0
fi

# Check cache (60 min TTL)
if [ -f "$CACHE_FILE" ]; then
  STALE=$(find "$CACHE_FILE" -mmin +60 2>/dev/null || true)
  if [ -z "$STALE" ]; then
    CACHED="$(cat "$CACHE_FILE" 2>/dev/null || true)"
    case "$CACHED" in
      UP_TO_DATE) exit 0 ;;
      UPGRADE_AVAILABLE*)
        CACHED_LOCAL="$(echo "$CACHED" | awk '{print $2}')"
        if [ "$CACHED_LOCAL" = "$LOCAL" ]; then
          echo "$CACHED"
          exit 0
        fi
        ;;
    esac
  fi
fi

# Fetch remote version
mkdir -p "$STATE_DIR"
REMOTE="$(curl -sf --max-time 5 "$REMOTE_URL" 2>/dev/null || true)"
REMOTE="$(echo "$REMOTE" | tr -d '[:space:]')"

# Validate
if ! echo "$REMOTE" | grep -qE '^[0-9]+\.[0-9.]+$'; then
  echo "UP_TO_DATE" > "$CACHE_FILE"
  exit 0
fi

if [ "$LOCAL" = "$REMOTE" ]; then
  echo "UP_TO_DATE" > "$CACHE_FILE"
  exit 0
fi

echo "UPGRADE_AVAILABLE $LOCAL $REMOTE" > "$CACHE_FILE"
echo "UPGRADE_AVAILABLE $LOCAL $REMOTE"
